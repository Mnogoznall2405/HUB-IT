# Mail / Exchange integration
MAIL_MODULE_ENABLED=0
# Фоновые push-уведомления о новой почте (как у chat; нужны WEB_PUSH_*)
MAIL_NOTIFICATION_BACKGROUND_ENABLED=1
MAIL_NOTIFICATION_MAX_CONCURRENCY=8
MAIL_NOTIFICATION_USER_TIMEOUT_SEC=15
# Badge/feed/bootstrap auto reads use the shared app snapshot. Set 0 only for rollback to live EWS reads.
MAIL_SHARED_SNAPSHOT_READ_ENABLED=1
MAIL_EXCHANGE_MAX_CONCURRENCY=16
MAIL_EXCHANGE_HOST=10.103.0.51
MAIL_EWS_URL=https://10.103.0.51/EWS/Exchange.asmx
# Optional: remote Exchange quota export (scripts/export_exchange_mailbox_quotas.ps1; do not commit real values)
# Prefer FQDN here instead of IP when running from your workstation.
EXCHANGE_QUOTA_SERVER=tmn-srv-exch-01.zsgp.corp
EXCHANGE_QUOTA_USERNAME=DOMAIN\\service_account
EXCHANGE_QUOTA_PASSWORD=change_me
# Mailbox quota JSON import from domain collector PC (scripts/mail_box_sync_domain.ps1)
MAIL_QUOTA_IMPORT_API_KEY=change_me
# Optional comma-separated key ring for rotation
MAIL_QUOTA_IMPORT_API_KEYS=
MAIL_QUOTA_SNAPSHOT_RETENTION_DAYS=90
MAIL_QUOTA_MAX_UPLOAD_MB=25
# When Exchange reports unlimited mailbox quota, treat as this limit (GB) for % and alerts
MAIL_QUOTA_DEFAULT_GB=5
# Keep TLS verification enabled. Use MAIL_TLS_CA_BUNDLE for an internal Exchange CA.
MAIL_VERIFY_TLS=1
MAIL_TLS_CA_BUNDLE=
MAIL_CACHE_TTL_SEC=90
# Full message bodies stay process-local and bounded; attachments are not included.
MAIL_DETAIL_CACHE_TTL_SEC=600
MAIL_BOOTSTRAP_DEFAULT_LIMIT=20
MAIL_IT_RECIPIENTS=it@zsgp.ru
MAIL_LOG_RETENTION_DAYS=90
MAIL_SEARCH_WINDOW_LIMIT=1000
MAIL_MAX_FILES=10
MAIL_MAX_FILE_SIZE_MB=15
MAIL_MAX_TOTAL_SIZE_MB=25
# Either a Fernet key or any passphrase (will be derived with SHA-256)
MAIL_CREDENTIALS_KEY=change_me_to_secure_random_value
# Separate key for the password vault. Do not reuse MAIL_CREDENTIALS_KEY.
PASSWORD_VAULT_KEY=change_me_to_secure_random_value
# Optional previous vault key after PASSWORD_VAULT_KEY rotation (scripts/password_vault_decrypt_audit.py).
PASSWORD_VAULT_KEY_LEGACY=

# Frontend build flag (rebuild frontend after change)
VITE_MAIL_MODULE_ENABLED=0
VITE_API_URL=/api
VITE_BACKEND_HOST=localhost
VITE_BACKEND_PORT=8001
VITE_BASE_PATH=/

# WEB backend
APP_ENV=development
BACKEND_PORT=8001
DEBUG=false
# Temporary mobile UX debug relay: POST /api/v1/debug/client-log -> WEB-itinvent/debug-{SESSION}.log
DEBUG_CLIENT_LOG_ENABLED=0
DEBUG_CLIENT_LOG_SESSION=891634
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
JWT_EXPIRE_MINUTES=480
# Generate strong random values for production, for example:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=
JWT_SECRET_KEYS=
AUTH_COOKIE_NAME=itinvent_access_token
AUTH_REFRESH_COOKIE_NAME=itinvent_refresh_token
# Keep true in production. For local HTTP-only development you may explicitly set false.
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=Strict
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
# Auth runtime state uses APP_DATABASE_URL on Windows Server. Leave Redis empty unless chat realtime explicitly needs it.
REDIS_URL=
REDIS_PASSWORD=
CHAT_REDIS_CHANNEL=itinvent:chat:events
CHAT_REALTIME_NODE_ID=
CHAT_PRESENCE_PREFIX=itinvent:chat:presence:user
CHAT_PRESENCE_TTL_SEC=75
CHAT_PRESENCE_WATCH_LIMIT=50
CHAT_WS_OUTBOUND_QUEUE_SIZE=256
CHAT_TYPING_STARTED_THROTTLE_SEC=2
CHAT_TYPING_STATE_TTL_SEC=5
AUTH_2FA_ENFORCED=1
AUTH_2FA_POLICY=external_only
AUTH_2FA_INTERNAL_CIDRS=10.0.0.0/8
AUTH_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
TOTP_ISSUER=HUB-IT
# Display name in otpauth path (authenticator apps). Apple Passwords issuer domain comes from WEBAUTHN_RP_ID.
AUTH_2FA_CHALLENGE_TTL_SEC=300
AUTH_BACKUP_CODES_COUNT=10
WEBAUTHN_RP_ID=hubit.zsgp.ru
WEBAUTHN_RP_NAME=HUB-IT
WEBAUTHN_ORIGIN=https://hubit.zsgp.ru
# Passkey only for external network by default. Set 1 only if passkey must work on corp 10.x Wi-Fi.
AUTH_PASSKEY_ALLOW_INTERNAL=0
AUTH_TRUSTED_DEVICE_TTL_DAYS=90
# Email alert on each successful login. Keep 0 unless security team explicitly needs it.
AUTH_NEW_LOGIN_EMAIL_ENABLED=0
RATE_LIMIT_STORAGE_URL=
SESSION_IDLE_TIMEOUT_MINUTES=30
SESSION_IDLE_TIMEOUT_TRUSTED_DAYS=7
SESSION_HISTORY_RETENTION_DAYS=14
SESSION_CLEANUP_MIN_INTERVAL_SECONDS=300
LDAP_SYNC_USER=your_user@domain.local
LDAP_SYNC_PASSWORD=your_password
LDAP_SYNC_INTERVAL_SECONDS=86400
LDAP_APP_USER_SYNC_ENABLED=1
LDAP_APP_USER_SYNC_INTERVAL_SECONDS=86400
LDAP_APP_USER_IMPORT_PERSON_ONLY=1

# Address book — sync employee contacts from 1C ZUP (V83.COMConnector, Windows only)
# Used by /address-book page and POST /api/v1/address-book/sync
ADDRESS_BOOK_SYNC_ENABLED=0
# Comma-separated 1C cluster servers (default matches corporate ZUP cluster)
ADDRESS_BOOK_1C_SERVER=tmn-srv-1c-01.zsgp.corp,tmn-srv-1c-02.zsgp.corp
# 1C infobase name (publication ref)
ADDRESS_BOOK_1C_REF=zar31
ADDRESS_BOOK_1C_USER=your_1c_username
ADDRESS_BOOK_1C_PASSWORD=your_1c_password
# Background sync interval in seconds (min 300, default 14400 = 4h)
ADDRESS_BOOK_SYNC_INTERVAL_SECONDS=14400

# Warehouse 1C — live Остатки/Ведомость с деньгами from 1C Бухгалтерия 2.0 (buh20)
# via V83.COMConnector (Windows only). Used by /warehouse-1c page.
# Comma-separated 1C cluster servers (default matches corporate buh20 cluster)
BUH20_1C_SERVER=tmn-srv-1c-01.zsgp.corp,tmn-srv-1c-02.zsgp.corp
# 1C infobase name (publication ref)
BUH20_1C_REF=buh20
BUH20_1C_USER=your_1c_username
BUH20_1C_PASSWORD=your_1c_password
# Background sync of Номенклатура/Склады directories into a local cache, so
# autocomplete filters in memory instead of hitting 1C on every keystroke.
# Live Остатки/Ведомость queries are never cached and always hit 1C directly.
WAREHOUSE_1C_CATALOG_SYNC_ENABLED=1
# Background sync interval in seconds (min 300, default 3600 = 1h)
WAREHOUSE_1C_CATALOG_SYNC_INTERVAL_SECONDS=3600
# Mark the catalogue stale after this many seconds; stale/error data must not
# be interpreted as a zero 1C balance.
WAREHOUSE_1C_CATALOG_STALE_SECONDS=7200
# Where the read-only 1C directory snapshot is served from: auto uses the
# indexed app database when APP_DATABASE_URL is configured; set 0 only for a
# controlled rollback to the legacy JSON cache.
WAREHOUSE_1C_CATALOG_APP_STORAGE=auto
# Enable only after the read-only child-process bridge is validated in the
# target Windows environment. When enabled, a timeout restarts the child and
# is returned as unknown/error; it never falls back to in-process COM.
WAREHOUSE_1C_PROCESS_BRIDGE_ENABLED=0
WAREHOUSE_1C_BRIDGE_QUEUE_LIMIT=16
WAREHOUSE_1C_BRIDGE_FAILURE_THRESHOLD=4
WAREHOUSE_1C_BRIDGE_COOLDOWN_SECONDS=60
WAREHOUSE_1C_BRIDGE_MAX_MESSAGE_BYTES=8388608
# Bounded download limit for 1C document attachments (bytes).
WAREHOUSE_1C_MAX_ATTACHED_FILE_BYTES=26214400
# Keep 0 during audit-only rollout.  Setting 1 enables a separately
# permission-checked, confirmed HUB-side reconcile write (registry links,
# owner mappings and legacy PART_NO projection). It never writes a document
# or balance to 1C.
WAREHOUSE_1C_RECONCILE_REGISTRY_WRITE_ENABLED=1
# Cross-DB 1C reconciliation is admin-only and fails closed unless every HUB
# database visible in scope=all is explicitly named here (comma-separated).
# Leave blank to disable scope=all entirely.
WAREHOUSE_1C_RECONCILE_ALLOWED_DB_IDS=

# Optional explicit DB config alias for ITINVENT
DB_ITINVENT_HOST=your_sql_server_host
DB_ITINVENT_DATABASE=ITINVENT
DB_ITINVENT_USERNAME=your_sql_username
DB_ITINVENT_PASSWORD=your_sql_password

# Branch databases (each needs all four DB_<ID>_* variables)
DB_MSK-ITINVENT_HOST=your_sql_server_host
DB_MSK-ITINVENT_DATABASE=MSK-ITINVENT
DB_MSK-ITINVENT_USERNAME=your_sql_username
DB_MSK-ITINVENT_PASSWORD=your_sql_password

DB_OBJ-ITINVENT_HOST=your_sql_server_host
DB_OBJ-ITINVENT_DATABASE=OBJ-ITINVENT
DB_OBJ-ITINVENT_USERNAME=your_sql_username
DB_OBJ-ITINVENT_PASSWORD=your_sql_password

DB_SPB-ITINVENT_HOST=your_sql_server_host
DB_SPB-ITINVENT_DATABASE=SPB-ITINVENT
DB_SPB-ITINVENT_USERNAME=your_sql_username
DB_SPB-ITINVENT_PASSWORD=your_sql_password

# Chat Web Push
# Generate: python scripts/generate_web_push_vapid_keys.py
WEB_PUSH_PUBLIC_KEY=your_vapid_public_key
WEB_PUSH_PRIVATE_KEY=your_vapid_private_key
WEB_PUSH_SUBJECT=mailto:it@zsgp.ru

# Native Android push through Firebase Cloud Messaging HTTP v1.
# Put either inline JSON or a path to a service-account JSON file.
FCM_PROJECT_ID=your_firebase_project_id
FCM_SERVICE_ACCOUNT_FILE=
FCM_SERVICE_ACCOUNT_JSON=
BACKEND_HOST=127.0.0.1
