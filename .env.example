MAIL_OFFICE_PREVIEW_ENABLED=1
MAIL_OFFICE_PREVIEW_MAX_BYTES=26214400
MAIL_OFFICE_PREVIEW_TIMEOUT_SEC=120
# Empty = auto-detect (Windows: C:\Program Files\LibreOffice\program\soffice.exe)
