# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_GROUP_ID=your_group_id_here
ALLOWED_USERS=user_id1,user_id2,user_id3

# OpenRouter API Configuration (единый LLM gateway: shared/llm)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Модели по назначению (fallback-цепочки в shared/llm/models.py):
# mail:      OPENROUTER_MODEL_MAIL → CHAT → MARKDOWN → ACT_PARSE → OCR → default
# chat:      OPENROUTER_MODEL_CHAT → MARKDOWN → ACT_PARSE → OCR → openai/gpt-4o-mini
# markdown:  OPENROUTER_MODEL_MARKDOWN → ACT_PARSE → OCR → default
# act:       ACT_PARSE_MODEL → OCR_MODEL
# ocr:       OCR_MODEL → default
OPENROUTER_MODEL_MAIL=deepseek/deepseek-v4-flash
OPENROUTER_MODEL_CHAT=
OPENROUTER_MODEL_MARKDOWN=
ACT_PARSE_MODEL=
OCR_MODEL=qwen/qwen3-vl-8b-instruct

# OpenRouter gateway retry / reliability (shared/llm)
AI_OPENROUTER_MAX_RETRIES=3
AI_OPENROUTER_RETRY_BASE_DELAY=0.8
AI_OPENROUTER_RETRY_MAX_DELAY=8.0
# Default request timeout is 45s; markdown transform uses per-call timeout=20s

# Unused (зарезервировано, код не читает): CARTRIDGE_ANALYSIS_MODEL
# CARTRIDGE_ANALYSIS_MODEL=anthropic/claude-3.5-sonnet

# Database Configuration
SQL_SERVER_HOST=your_sql_server_host
SQL_SERVER_DATABASE=ITINVENT
SQL_SERVER_USERNAME=your_sql_username
SQL_SERVER_PASSWORD=your_sql_password
AVAILABLE_DATABASES=ITINVENT,MSK-ITINVENT,OBJ-ITINVENT,SPB-ITINVENT
# ITINVENT VARCHAR/CHAR are usually Windows-1251; NVARCHAR/NCHAR need UTF-16-LE (not UTF-8).
SQL_CHAR_ENCODING=cp1251
SQL_WCHAR_ENCODING=utf-16-le

# Unified internal PostgreSQL for app-owned runtime data
# Required when APP_ENV=production. JSON runtime storage does not fall back
# to legacy SQLite in production; migrate it with scripts/migrate_json_store_sqlite_to_postgres.py.
# Example: postgresql+psycopg://postgres:postgres@localhost:5432/itinvent
APP_DATABASE_URL=
APP_DB_POOL_SIZE=10
APP_DB_MAX_OVERFLOW=10
APP_DB_APPLICATION_NAME=itinvent-backend
CHAT_DB_POOL_SIZE=5
CHAT_DB_MAX_OVERFLOW=5
CHAT_DB_APPLICATION_NAME=itinvent-backend-chat
APP_DB_ECHO=0
REQUEST_METRICS_ENABLED=1
REQUEST_METRICS_SLOW_MS=1000
REQUEST_METRICS_MAX_ROUTES=300
REQUEST_METRICS_SAMPLE_SIZE=512
SQL_SLOW_LOG_MS=250
# Set to 1 to skip auto-update of documentation/technical/POSTGRES_APP_SCHEMA*.md after Alembic / dev PG init
SKIP_PG_SCHEMA_DOCS=0

# Public share links for "My files" (/api/v1/my-files/public/*) — per-token and per-IP buckets
MY_FILES_PUBLIC_META_LIMIT_PER_TOKEN=60
MY_FILES_PUBLIC_META_WINDOW_TOKEN_SEC=600
MY_FILES_PUBLIC_META_LIMIT_PER_IP=120
MY_FILES_PUBLIC_META_WINDOW_IP_SEC=60
MY_FILES_PUBLIC_DOWNLOAD_LIMIT_PER_TOKEN=15
MY_FILES_PUBLIC_DOWNLOAD_WINDOW_TOKEN_SEC=600
MY_FILES_PUBLIC_DOWNLOAD_LIMIT_PER_IP=80
MY_FILES_PUBLIC_DOWNLOAD_WINDOW_IP_SEC=3600
MY_FILES_PUBLIC_MISS_LIMIT_PER_IP=60
MY_FILES_PUBLIC_MISS_WINDOW_IP_SEC=60
# One-time owner download grants (native browser download, 2 min TTL by default)
MY_FILES_DOWNLOAD_GRANT_TTL_SEC=120
MY_FILES_DOWNLOAD_GRANT_MINT_LIMIT_PER_USER=40
MY_FILES_DOWNLOAD_GRANT_MINT_WINDOW_USER_SEC=60
MY_FILES_DOWNLOAD_GRANT_MINT_LIMIT_PER_IP=80
MY_FILES_DOWNLOAD_GRANT_MINT_WINDOW_IP_SEC=60
MY_FILES_DOWNLOAD_GRANT_CONSUME_LIMIT_PER_IP=120
MY_FILES_DOWNLOAD_GRANT_CONSUME_WINDOW_IP_SEC=60
MY_FILES_DOWNLOAD_GRANT_MISS_LIMIT_PER_IP=60
MY_FILES_DOWNLOAD_GRANT_MISS_WINDOW_IP_SEC=60
# Authenticated upload throttling and queue reservations. Internal requests are not exempt.
MY_FILES_UPLOAD_LIMIT_PER_USER=30
MY_FILES_UPLOAD_WINDOW_USER_SEC=600
MY_FILES_UPLOAD_LIMIT_PER_IP=100
MY_FILES_UPLOAD_WINDOW_IP_SEC=600
MY_FILES_MAX_UPLOADING_PER_USER=2
MY_FILES_MAX_UPLOADING_GLOBAL=8
MY_FILES_MAX_ACTIVE_JOBS_PER_USER=5
MY_FILES_MAX_ACTIVE_JOBS_GLOBAL=100
MY_FILES_MAX_PROCESSING_GLOBAL=1
MY_FILES_UPLOAD_RESERVATION_TTL_SEC=7200
MY_FILES_PROCESSING_TIMEOUT_SEC=21600
# Production runs this worker separately under PM2.
MY_FILES_INLINE_WORKER_ENABLED=0
MY_FILES_ZSTD_THREADS=2
# Microsoft Defender custom scan. Production defaults to enabled and fail-closed.
MY_FILES_ANTIVIRUS_ENABLED=1
MY_FILES_ANTIVIRUS_FAIL_CLOSED=1
MY_FILES_ANTIVIRUS_TIMEOUT_SEC=300
MY_FILES_DEFENDER_PATH=
# Separate encryption key for stable public share links. Do not reuse other keys.
MY_FILES_SHARE_TOKEN_KEY=change_me_to_secure_random_value

# Enable corporate chat HTTP API, websocket and runtime
CHAT_MODULE_ENABLED=0
VITE_CHAT_ENABLED=0
VITE_CHAT_WS_ENABLED=0
# Task comments -> corporate chat (requires CHAT_MODULE_ENABLED=1)
TASK_DISCUSSION_CHAT_ENABLED=0
VITE_TASK_DISCUSSION_CHAT_ENABLED=0
# Optional chat-specific override; if empty, chat can fall back to APP_DATABASE_URL
CHAT_DATABASE_URL=

# Additional Databases (опционально)
ITINVENT2_HOST=secondary_server_host
ITINVENT2_DATABASE=ITINVENT2

