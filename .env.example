TASK_EMAIL_FROM_NAME=HUB-IT
TASK_EMAIL_APP_URL=https://hub-it.yourdomain.com
TASK_EMAIL_DEADLINE_SOON_HOURS=24
TASK_EMAIL_TRANSPORT=exchange
TASK_EMAIL_EWS_LOGIN=hub-it@yourdomain.com
TASK_EMAIL_EWS_PASSWORD=
TASK_EMAIL_DESCRIPTION_MAX_CHARS=300
TASK_EMAIL_SMTP_TIMEOUT_SECONDS=5
# Фоновый цикл напоминаний о сроках задач (in-app + email outbox), не в poll/unread-counts
TASK_DUE_NOTIFICATION_BACKGROUND_ENABLED=1
TASK_DUE_NOTIFICATION_INTERVAL_SECONDS=600
TASK_DUE_NOTIFICATION_STARTUP_DELAY_SECONDS=60
# Security email about new account login. Disabled by default.
AUTH_NEW_LOGIN_EMAIL_ENABLED=0

# Other Configuration
TRANSFER_TEMPLATE_PATH=templates/docx_transfer_act.docx
TRANSFER_ACTS_DIR=transfer_acts
MAX_TRANSFER_PHOTOS=10

# Scan Server / Scan Agent
SCAN_SERVER_HOST=127.0.0.1
