# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_GROUP_ID=your_group_id_here
ALLOWED_USERS=user_id1,user_id2,user_id3

# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# AI Models Configuration (опционально)
# OCR модель для распознавания серийных номеров
OCR_MODEL=qwen/qwen3-vl-8b-instruct

# Модель для анализа замен картриджей
CARTRIDGE_ANALYSIS_MODEL=anthropic/claude-3.5-sonnet

# Доступные модели для CARTRIDGE_ANALYSIS_MODEL:
# anthropic/claude-3.5-sonnet - лучшая для структурирования данных
# anthropic/claude-3-haiku - быстрая и дешевая
# openai/gpt-4o - мощная модель от OpenAI
# openai/gpt-4o-mini - экономичная версия
# google/gemini-1.5-pro - модель от Google
# meta-llama/llama-3.1-405b - открытая модель

# Database Configuration
SQL_SERVER_HOST=your_sql_server_host
SQL_SERVER_DATABASE=ITINVENT
SQL_SERVER_USERNAME=your_sql_username
SQL_SERVER_PASSWORD=your_sql_password
AVAILABLE_DATABASES=ITINVENT,ITINVENT2

# Unified internal PostgreSQL for app-owned runtime data
# Example: postgresql+psycopg://postgres:postgres@localhost:5432/itinvent
APP_DATABASE_URL=
APP_DB_POOL_SIZE=10
APP_DB_MAX_OVERFLOW=20
APP_DB_ECHO=0

# Optional chat-specific override; if empty, chat can fall back to APP_DATABASE_URL
CHAT_DATABASE_URL=

# Additional Databases (опционально)
ITINVENT2_HOST=secondary_server_host
ITINVENT2_DATABASE=ITINVENT2

# SMTP Configuration (для email отправки)
SMTP_SERVER=your_smtp_server
EMAIL_ADDRESS=bot@yourdomain.com
EMAIL_PASSWORD=your_email_password

# Other Configuration
TRANSFER_TEMPLATE_PATH=templates/docx_transfer_act.docx
TRANSFER_ACTS_DIR=transfer_acts
MAX_TRANSFER_PHOTOS=10

# Scan Server / Scan Agent
SCAN_SERVER_HOST=127.0.0.1
SCAN_SERVER_PORT=8011
SCAN_SERVER_WATCHDOG_ENABLED=1
SCAN_SERVER_WATCHDOG_INTERVAL_SEC=30
SCAN_SERVER_WATCHDOG_TIMEOUT_SEC=3
SCAN_SERVER_WATCHDOG_FAILURES=3
SCAN_SERVER_WATCHDOG_STARTUP_GRACE_SEC=20
SCAN_SERVER_API_KEYS=
# Legacy single-key fallback (transition only):
SCAN_SERVER_API_KEY=
SCAN_RETENTION_DAYS=90
SCAN_TASK_TTL_DAYS=7
SCAN_TASK_ACK_TIMEOUT_SEC=300

ITINV_AGENT_SERVER_URL=https://hubit.zsgp.ru/api/v1/inventory
ITINV_AGENT_API_KEY=
# Backend inventory key-ring (comma-separated):
ITINV_AGENT_API_KEYS=
ITINV_AGENT_ALLOW_DEFAULT_KEY=1
ITINV_AGENT_INTERVAL_SEC=3600
ITINV_AGENT_HEARTBEAT_SEC=300
ITINV_AGENT_HEARTBEAT_JITTER_SEC=0
ITINV_OUTLOOK_REFRESH_SEC=300
ITINV_OUTLOOK_SEARCH_ROOTS=D:\
ITINV_RUN_CMD_TIMEOUT_SEC=20
ITINV_INVENTORY_QUEUE_BATCH=50
ITINV_INVENTORY_QUEUE_MAX_ITEMS=1000
ITINV_INVENTORY_QUEUE_MAX_AGE_DAYS=14
ITINV_INVENTORY_QUEUE_MAX_TOTAL_MB=256
ITINV_AGENT_CA_BUNDLE=
ITINV_SCAN_ENABLED=1
ITINV_REBOOT_REMINDER_ENABLED=1
ITINV_REBOOT_REMINDER_DAYS=7
ITINV_REBOOT_REMINDER_INTERVAL_HOURS=24
ITINV_REBOOT_REMINDER_TIMEOUT_SEC=120
ITINV_REBOOT_REMINDER_WORK_START_HOUR=9
ITINV_REBOOT_REMINDER_WORK_END_HOUR=18
ITINV_REBOOT_REMINDER_WEEKDAYS_ONLY=1
# Optional explicit path for agent-side .env loading (example: C:\Program Files\IT-Invent\Agent\.env)
# ITINV_AGENT_ENV_FILE=
SCAN_AGENT_SERVER_BASE=https://hubit.zsgp.ru/api/v1/scan
SCAN_AGENT_API_KEY=
SCAN_AGENT_POLL_INTERVAL_SEC=60
SCAN_AGENT_MAX_FILE_MB=50
SCAN_AGENT_SCAN_ON_START=0
SCAN_AGENT_WATCHDOG_ENABLED=0
SCAN_AGENT_WATCHDOG_BATCH_SIZE=200
SCAN_AGENT_ROOTS_REFRESH_SEC=300
SCAN_AGENT_OUTBOX_MAX_ITEMS=5000
SCAN_AGENT_OUTBOX_MAX_AGE_DAYS=14
SCAN_AGENT_OUTBOX_MAX_TOTAL_MB=512

# MFU Runtime Monitor (ping + SNMP)
MFU_PING_INTERVAL_SEC=60
MFU_PING_TIMEOUT_MS=900
MFU_PING_CONCURRENCY=16
MFU_RUNTIME_MONITOR_ENABLED=1
MFU_SNMP_ENABLED=1
MFU_SNMP_INTERVAL_SEC=300
MFU_SNMP_CONCURRENCY=3
MFU_SNMP_COMMUNITY=public
MFU_SNMP_RETRIES=1
MFU_SNMP_TIMEOUT_SEC=2.5
MFU_SNMP_PROBE_TIMEOUT_SEC=35
MFU_SNMP_MAX_SUPPLIES=8
MFU_SNMP_MARKER_SCAN_MAX=3
MFU_SNMP_INDEX_REFRESH_SEC=21600
MFU_SNMP_WALK_BUDGET_SEC=8
MFU_SNMP_WALK_MAX_ROWS=24
MFU_SNMP_WALK_RETRIES=0
MFU_SNMP_BACKOFF_BASE_SEC=60
MFU_SNMP_BACKOFF_MAX_SEC=900
MFU_SNMP_OFFLINE_RETRY_SEC=900
MFU_SNMP_NO_DATA_BACKOFF_SEC=3600
MFU_SNMP_ACTIVE_TTL_SEC=3600
MFU_RUNTIME_PERSIST_ENABLED=1
MFU_RUNTIME_STATE_TTL_DAYS=30
MFU_PAGE_SNAPSHOT_TTL_DAYS=400
MFU_PAGE_MONTHS_DEFAULT=12
MFU_PAGE_SNAPSHOT_CLEANUP_INTERVAL_SEC=21600

# Mail / Exchange integration
MAIL_MODULE_ENABLED=0
MAIL_NOTIFICATION_BACKGROUND_ENABLED=0
MAIL_NOTIFICATION_MAX_CONCURRENCY=8
MAIL_EXCHANGE_HOST=10.103.0.51
MAIL_EWS_URL=https://10.103.0.51/EWS/Exchange.asmx
MAIL_VERIFY_TLS=1
MAIL_CACHE_TTL_SEC=90
MAIL_BOOTSTRAP_DEFAULT_LIMIT=20
MAIL_IT_RECIPIENTS=it@zsgp.ru
MAIL_LOG_RETENTION_DAYS=90
MAIL_SEARCH_WINDOW_LIMIT=1000
MAIL_MAX_FILES=10
MAIL_MAX_FILE_SIZE_MB=15
MAIL_MAX_TOTAL_SIZE_MB=25
# Either a Fernet key or any passphrase (will be derived with SHA-256)
MAIL_CREDENTIALS_KEY=change_me_to_secure_random_value

# Frontend build flag (rebuild frontend after change)
VITE_MAIL_MODULE_ENABLED=0
VITE_API_URL=/api
VITE_BACKEND_HOST=localhost
VITE_BACKEND_PORT=8001
VITE_BASE_PATH=/

# WEB backend
BACKEND_PORT=8001
DEBUG=false
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
JWT_EXPIRE_MINUTES=480
JWT_SECRET_KEY=change-this-to-random-string-in-production
JWT_SECRET_KEYS=NEW_SECRET,OLD_SECRET
AUTH_COOKIE_NAME=itinvent_access_token
AUTH_REFRESH_COOKIE_NAME=itinvent_refresh_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Strict
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
# Auth runtime state uses APP_DATABASE_URL on Windows Server. Leave Redis empty unless chat realtime explicitly needs it.
REDIS_URL=
REDIS_PASSWORD=
CHAT_REDIS_CHANNEL=itinvent:chat:events
CHAT_REALTIME_NODE_ID=
CHAT_PRESENCE_PREFIX=itinvent:chat:presence:user
CHAT_PRESENCE_TTL_SEC=75
CHAT_PRESENCE_WATCH_LIMIT=50
CHAT_WS_OUTBOUND_QUEUE_SIZE=256
CHAT_TYPING_STARTED_THROTTLE_SEC=2
CHAT_TYPING_STATE_TTL_SEC=5
AUTH_2FA_ENFORCED=1
AUTH_2FA_POLICY=external_only
AUTH_2FA_INTERNAL_CIDRS=10.0.0.0/8
AUTH_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
TOTP_ISSUER=HUB-IT
AUTH_2FA_CHALLENGE_TTL_SEC=300
AUTH_BACKUP_CODES_COUNT=10
WEBAUTHN_RP_ID=hubit.zsgp.ru
WEBAUTHN_RP_NAME=HUB-IT
WEBAUTHN_ORIGIN=https://hubit.zsgp.ru
AUTH_TRUSTED_DEVICE_TTL_DAYS=90
AUTH_NEW_LOGIN_EMAIL_ENABLED=1
RATE_LIMIT_STORAGE_URL=
SESSION_IDLE_TIMEOUT_MINUTES=30
SESSION_HISTORY_RETENTION_DAYS=14
SESSION_CLEANUP_MIN_INTERVAL_SECONDS=300
LDAP_SYNC_USER=your_user@domain.local
LDAP_SYNC_PASSWORD=your_password
LDAP_SYNC_INTERVAL_SECONDS=86400

# Optional explicit DB config alias for ITINVENT
DB_ITINVENT_HOST=your_sql_server_host
DB_ITINVENT_DATABASE=ITINVENT
DB_ITINVENT_USERNAME=your_sql_username
DB_ITINVENT_PASSWORD=your_sql_password

# Chat Web Push
WEB_PUSH_PUBLIC_KEY=your_vapid_public_key
WEB_PUSH_PRIVATE_KEY=your_vapid_private_key
WEB_PUSH_SUBJECT=mailto:admin@example.com
BACKEND_HOST=127.0.0.1
