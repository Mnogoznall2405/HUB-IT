flowchart LR
    A[Excel-файл .xlsx] --> B[Загрузка в систему]
    B --> C[Предпросмотр листов]
    C --> D{Сопоставление}
    D --> E[Лист → объект / филиал]
    D --> F[Цвет ячейки → статус заявки]
    D --> G[Стратегия дубликатов]
    G --> H[Пропустить / обновить]
    E --> I[Запуск импорта]
    F --> I
    H --> I
    I --> J[Создание заявок]
    I --> K[Сохранение сырой строки для аудита]
    J --> L[Список и канбан]
    K --> L

    subgraph colors [Типовые цвета Excel]
        C1[Белый — новая]
        C2[Зелёный — куплен]
        C3[Жёлтый — в работе]
        C4[Красный — отмена]
        C5[Оранжевый — нужен обмен]
    end

    F -.-> colors
